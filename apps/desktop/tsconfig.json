{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "isolatedModules": false,
    "types": ["node", "electron"]
  },
  "include": ["src/**/*.ts", "src/**/*.cts"],
  "exclude": ["dist", "src/**/*.test.ts"]
}
